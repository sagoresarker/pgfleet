# Copy to .env and adjust. `make run` loads this.

# --- required ---
PGFLEET_META_DB_DSN=postgres://pgfleet:pgfleet@localhost:5433/pgfleet?sslmode=disable
# 32 bytes, base64-encoded (generate: openssl rand -base64 32)
PGFLEET_MASTER_KEY=MDEyMzQ1Njc4OWFiY2RlZjAxMjM0NTY3ODlhYmNkZWY=
# at least 32 bytes (generate: openssl rand -hex 32)
PGFLEET_JWT_SECRET=change-me-to-a-long-random-string-at-least-32b

# --- first admin (seeded once on an empty database) ---
PGFLEET_BOOTSTRAP_ADMIN_EMAIL=admin@pgfleet.local
PGFLEET_BOOTSTRAP_ADMIN_PASSWORD=change-me-please

# --- server ---
PGFLEET_HTTP_ADDR=:8080
PGFLEET_LOG_LEVEL=info
PGFLEET_INSTANCE_HOST=localhost
# Docker restart policy for managed instances + routers (unless-stopped | always | no)
PGFLEET_INSTANCE_RESTART_POLICY=unless-stopped
# Host interface published instance/router ports bind to. 127.0.0.1 = secure
# default (same-host/proxy access only). Set to a private IP or 0.0.0.0 to widen.
PGFLEET_INSTANCE_BIND_ADDRESS=127.0.0.1
# Optional: POST a JSON payload here on every alert transition (disk/lag/backup/conns)
PGFLEET_ALERT_WEBHOOK_URL=
# Automatic cluster failover (promote a replica when the primary dies). Default on.
PGFLEET_AUTO_FAILOVER=true

# --- backups (object store: the bundled MinIO) ---
PGFLEET_DEFAULT_REPO_TYPE=s3
PGFLEET_S3_ENDPOINT=localhost:9000
PGFLEET_S3_BUCKET=pgbackrest
PGFLEET_S3_REGION=us-east-1
PGFLEET_S3_ACCESS_KEY=pgfleet
PGFLEET_S3_SECRET_KEY=pgfleetpgfleet

# --- schedules ---
PGFLEET_BACKUP_INTERVAL=24h
PGFLEET_BACKUP_TYPE=full
PGFLEET_DOCKER_NETWORK=pgfleet
